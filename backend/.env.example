# Google Gemini API key (active AI provider for email parsing)
GEMINI_API_KEY=AIzaSy...

# Anthropic Claude API key (optional — for future use)
ANTHROPIC_API_KEY=

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# Firebase project config
FIREBASE_PROJECT_ID=job-tracker-xxxxx
FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/firebase-service-account.json

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://your-firebase-app.web.app,http://localhost:5173

# Google OAuth redirect URI (must match Google Cloud Console config)
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
